    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://api.mist.com/api/v1/sites/{{ $json.body.site_id }}/devices/{{ $json.body.device_id }}/reboot",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "=Token {{ $env.MIST_API_TOKEN }}" }
          ]
        },
        "options": { "response": { "response": { "neverError": true } } }
      },
      "id": "c1a2b3d4-e5f6-4890-ab01-001234567826",
      "name": "Mist RESTART Device",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [-480, 2000]
    },
    {
      "parameters": {
        "jsCode": "const action = $input.first().json.body?.action || $input.first().json?.action || 'unknown';\nreturn [{ json: { error: 'Unknown action', action, available: ['get_sites','get_devices','get_clients','get_alarms','restart_device'] } }];"
      },
      "id": "c1a2b3d4-e5f6-4890-ab01-001234567827",
