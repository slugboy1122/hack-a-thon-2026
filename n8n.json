    {
      "parameters": {
        "jsCode": "const b = $input.first().json.body || $input.first().json || {};\n\nconst system = `You are Marvis AI Ops for Juniper Mist. You help network operators query and manage Mist environments.\n\nAvailable actions you can trigger:\n- get_sites: list all org sites\n- get_devices: list devices at a site (needs site_id)\n- get_clients: client stats at a site (needs site_id)\n- get_alarms: active org alarms\n- update_wlan: modify WLAN config (needs wlan_id + config)\n- restart_device: reboot a device (needs device_id)\n\nAlways respond with valid JSON only, no markdown:\n{\"intent\": \"description\", \"action\": \"action_name or null\", \"params\": {}, \"response\": \"reply to operator\", \"needs_confirmation\": false}`;\n\nconst user = `Org ID: ${b.org_id || 'not provided'}\nSite ID: ${b.site_id || 'not provided'}\nQuery: ${b.query || b.message || ''}`;\n\nreturn [{ json: { system, user, org_id: b.org_id || '', site_id: b.site_id || '' } }];"
      },
      "id": "357e62ce-2378-4c1c-8748-ba7f92357703",
      "name": "Build Chat Intent",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -432,
        704
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-api-key",
              "value": "={{ $env.ANTHROPIC_API_KEY }}"
            },
            {
              "name": "anthropic-version",
              "value": "2023-06-01"
            },
            {
              "name": "content-type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"claude-sonnet-4-6\",\n  \"max_tokens\": 512,\n  \"system\": {{ JSON.stringify($json.system) }},\n  \"messages\": [{ \"role\": \"user\", \"content\": {{ JSON.stringify($json.user) }} }]\n}",
        "options": {
          "timeout": 30000
        }
      },
      "id": "6893feb3-99e0-41df-bd17-f1c89206e1e6",
      "name": "Claude Resolve Intent",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -208,
        704
      ]
    },
    {
      "parameters": {
        "jsCode": "const r = $input.first().json;\nconst raw = r.content?.[0]?.text || '{}';\nlet intent = {};\ntry {\n  intent = JSON.parse(raw.replace(/```json|```/g, '').trim());\n} catch(e) {\n  intent = { action: null, response: raw, needs_confirmation: false };\n}\nreturn [{ json: intent }];"
      },
      "id": "18d2c4f8-ec26-4843-9041-9d440179b3d3",
      "name": "Parse Chat Intent",
