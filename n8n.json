      "type": "n8n-nodes-base.switch",
      "typeVersion": 1,
      "position": [-720, 1600]
    },
    {
      "parameters": {
        "url": "=https://api.mist.com/api/v1/orgs/{{ $json.body.org_id || $env.MIST_DEFAULT_ORG_ID }}/sites",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "=Token {{ $env.MIST_API_TOKEN }}" }
          ]
        },
        "options": { "response": { "response": { "neverError": true } } }
      },
      "id": "c1a2b3d4-e5f6-4890-ab01-001234567822",
      "name": "Mist GET Sites",
