        ],
        "path": "mist-events",
        "options": {}
      },
      "id": "007bf57d-8b80-43f1-8f38-51da8e749398",
      "name": "Mist Webhook Receiver",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [
        -656,
        0
      ],
      "webhookId": "mist-events-001"
    },
    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json || {};\nconst events = body.events || [];\nconst topic = body.topic || 'unknown';\n\nconst HIGH_P = [\n  'device_down','switch_offline','gw_offline',\n  'marvis_ap_offline','bad_cable','auth_failure_rate',\n  'rogue_ap','honeypot_ssid','vssid_spoofing'\n];\n\nif (events.length === 0) {\n  return [{ json: { topic, event_type: 'ping', high_priority: false, site_name: 'n/a', device_name: 'n/a', device_mac: 'n/a', severity: 'info', count: 0, message: '', timestamp: Math.floor(Date.now()/1000), raw: {} } }];\n}\n\nreturn events.map(e => ({\n  json: {\n    topic,\n    event_type: e.type || e.alarm_type || 'unknown',\n    severity: e.severity || 'info',\n    site_id: e.site_id || '',\n    site_name: e.site_name || 'unknown',\n    org_id: e.org_id || '',\n    device_mac: e.ap || e.mac || e.switch_mac || '',\n    device_name: e.ap_name || e.device_name || '',\n    message: e.message || e.reason || '',\n    count: e.count || 1,\n    timestamp: e.timestamp || Math.floor(Date.now()/1000),\n    high_priority: HIGH_P.includes(e.type || e.alarm_type || ''),\n    raw: e\n  }\n}));"
      },
      "id": "5bf50c54-9d51-4864-9019-933aed46cefd",
      "name": "Normalize Event",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -656,
        384
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": false,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 1
          },
          "combinator": "and",
          "conditions": [
            {
              "leftValue": "={{ $json.high_priority }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true",
                "singleValue": true
              }
            }
          ]
        },
        "options": {}
      },
      "id": "5b7396a9-fa09-4e2b-97ae-9105573717f4",
      "name": "High Priority?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        -432,
        384
      ]
    },
    {
      "parameters": {
        "jsCode": "const e = $input.first().json;\n\nconst system = `You are Marvis AI Ops Assistant for Juniper Mist networks. You have deep expertise in:\n- Mist API (api.mist.com), MARVIS ML engine, all webhook topics\n- tmunzer/mist_library Python automation scripts (mistapi package)\n- AP troubleshooting: radio, RRM, 802.11r/k/v, RSSI thresholds\n- Switch/EX Series: PoE, port profiles, EVPN-VXLAN\n- SRX/SSR WAN: SD-WAN path selection, app-based steering\n- NAC: Mist Access Assurance, ClearPass integration\n- HPE Aruba Central and GreenLake networking\n\nFor each event: diagnose root cause using Marvis reasoning, recommend specific Mist API calls or tmunzer script commands to remediate, assign P1/P2/P3 priority.`;\n\nconst user = `MIST EVENT — Analysis Required\n\nTopic: ${e.topic}\nEvent: ${e.event_type}\nSeverity: ${e.severity}\nSite: ${e.site_name} (${e.site_id})\nDevice: ${e.device_name} [${e.device_mac}]\nCount: ${e.count}\nTime: ${new Date(e.timestamp * 1000).toISOString()}\n${e.message ? 'Message: ' + e.message : ''}\n\nRaw Payload:\n${JSON.stringify(e.raw, null, 2)}\n\nProvide:\n1. Root cause diagnosis\n2. Remediation steps (include Mist API calls or tmunzer script)\n3. Preventive recommendations\n4. Priority: P1/P2/P3`;\n\nreturn [{ json: { system, user, event_context: e } }];"
      },
      "id": "7a1e1a2b-199e-4acd-8a6f-49ee020de9d0",
      "name": "Build Analysis Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -208,
        288
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-api-key",
              "value": "={{ $env.ANTHROPIC_API_KEY }}"
            },
            {
              "name": "anthropic-version",
              "value": "2023-06-01"
            },
            {
              "name": "content-type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"claude-sonnet-4-6\",\n  \"max_tokens\": 2048,\n  \"system\": {{ JSON.stringify($json.system) }},\n  \"messages\": [{ \"role\": \"user\", \"content\": {{ JSON.stringify($json.user) }} }]\n}",
        "options": {
          "timeout": 60000
        }
      },
      "id": "a82f7dfe-8b47-4731-a541-d54ba51c87d7",
      "name": "Claude Analyze Event",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        16,
        288
      ]
    },
    {
      "parameters": {
        "jsCode": "const r = $input.first().json;\nconst text = r.content?.[0]?.text || 'No response from Claude';\nconst priority = (text.match(/Priority:\\s*(P[123])/i) || [])[1] || 'P2';\nconsole.log('Claude Analysis:', text.substring(0, 200));\nreturn [{ json: { analysis: text, priority, timestamp: new Date().toISOString() } }];"
      },
      "id": "b0fe4cb3-97a6-4703-9036-102aa8bc793b",
      "name": "Parse Analysis",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        240,
        288
      ]
    },
    {
      "parameters": {
        "jsCode": "const e = $input.first().json;\nconsole.log('LOW PRIORITY EVENT:', JSON.stringify({\n  ts: new Date().toISOString(),\n  type: e.event_type,\n  site: e.site_name,\n  device: e.device_name\n}));\nreturn [{ json: { logged: true, event_type: e.event_type, ts: new Date().toISOString() } }];"
      },
      "id": "111598e0-b804-4875-a288-723ae70122c1",
      "name": "Log Low Priority",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -208,
        480
      ]
    },
    {
