          "rules": [
            { "value2": "get_sites" },
            { "value2": "get_devices", "output": 1 },
            { "value2": "get_clients", "output": 2 },
            { "value2": "get_alarms",  "output": 3 },
            { "value2": "restart_device", "output": 4 }
          ]
        },
        "fallbackOutput": 5
      },
      "id": "c1a2b3d4-e5f6-4890-ab01-001234567821",
